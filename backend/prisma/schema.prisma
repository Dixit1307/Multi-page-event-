datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String?
  provider  String?
  createdAt DateTime @default(now())
  events    Event[]
}

model Event {
  id       String   @id @default(uuid())
  title    String
  date     DateTime
  type     String
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  photos   Photo[]
}

model Photo {
  id        String   @id @default(uuid())
  imageUrl  String
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
}